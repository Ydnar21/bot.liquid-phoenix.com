{
  "entities": {
    "user": {
      "title": "User",
      "description": "User public profile information",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Firebase user unique ID"
        },
        "email": {
          "type": "string",
          "description": "User email address"
        },
        "displayName": {
          "type": "string",
          "description": "User display name"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Profile registration time"
        },
        "consentedToTerms": {
          "type": "boolean",
          "description": "Whether the user successfully completed legal onboarding and waiver signature"
        },
        "consentedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the consent agreement was formally submitted and recorded"
        }
      },
      "required": ["uid", "email"]
    },
    "userCredentials": {
      "title": "User Credentials",
      "description": "User's private Alpaca settings and keys",
      "type": "object",
      "properties": {
        "ALPACA_API_KEY": {
          "type": "string",
          "description": "Alpaca API Key ID"
        },
        "ALPACA_SECRET_KEY": {
          "type": "string",
          "description": "Alpaca Private Secret Key"
        },
        "ALPACA_BASE_URL": {
          "type": "string",
          "description": "Alpaca Endpoint routing base URL"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Time credentials were last updated"
        }
      },
      "required": ["ALPACA_API_KEY", "ALPACA_SECRET_KEY", "ALPACA_BASE_URL", "updatedAt"]
    },
    "globalTradingState": {
      "title": "Global Trading State",
      "description": "Persisted shared portfolio trading status and setups",
      "type": "object",
      "properties": {
        "activePosition": {
          "type": "object",
          "description": "Current open swing trade, if any"
        },
        "closedTrades": {
          "type": "array",
          "description": "Audited historic trade records"
        },
        "scannedSetups": {
          "type": "array",
          "description": "List of current identified stock setups"
        },
        "botConfig": {
          "type": "object",
          "description": "Shared scanning configurations"
        },
        "botState": {
          "type": "object",
          "description": "Consolidated state metrics"
        },
        "botLogs": {
          "type": "array",
          "description": "Unified execution log stream"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Database save timestamp"
        }
      },
      "required": ["updatedAt"]
    },
    "userTradingState": {
      "title": "User Trading State",
      "description": "Persisted individual user account portfolio trading status",
      "type": "object",
      "properties": {
        "activePosition": {
          "type": "object",
          "description": "User specific open swing trade, if any"
        },
        "closedTrades": {
          "type": "array",
          "description": "User specific audited historic trade records"
        },
        "botConfig": {
          "type": "object",
          "description": "User specific custom scanning and active trader settings"
        },
        "botState": {
          "type": "object",
          "description": "User specific live metrics"
        },
        "botLogs": {
          "type": "array",
          "description": "User specific execution log stream"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Database save timestamp"
        }
      },
      "required": ["updatedAt"]
    },
    "terminalWorkspace": {
      "title": "Terminal Workspace",
      "description": "User's sandboxed virtual filesystem workspace",
      "type": "object",
      "properties": {
        "files": {
          "type": "object",
          "description": "Virtual files stored in the terminal workspace"
        }
      },
      "required": ["files"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "user",
      "description": "User public profiles"
    },
    "users/{userId}/private/credentials": {
      "schema": "userCredentials",
      "description": "Isolated private credentials"
    },
    "users/{userId}/private/state": {
      "schema": "userTradingState",
      "description": "Isolated private trading state configuration for individual users"
    },
    "users/{userId}/terminal_v1/filesystem": {
      "schema": "terminalWorkspace",
      "description": "Persistent workspace file system for user's isolated sandboxed terminal"
    },
    "globalState/trading": {
      "schema": "globalTradingState",
      "description": "Shared persistent state of the active copy trading system"
    }
  }
}
