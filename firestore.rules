rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default Deny Catch-All Security Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Secure Global Primitive Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isVerifiedUser() {
      // Allow Google accounts or verified emails
      return isSignedIn() && (
        request.auth.token.email_verified == true || 
        request.auth.token.firebase.sign_in_provider == 'google.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Entity Structural Schema Validation helpers
    function isValidUser(data) {
      return data.uid is string && data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 256
        && data.displayName is string && data.displayName.size() <= 256;
    }

    function isValidCredentials(data) {
      return data.ALPACA_API_KEY is string && data.ALPACA_API_KEY.size() <= 128
        && data.ALPACA_SECRET_KEY is string && data.ALPACA_SECRET_KEY.size() <= 128
        && data.ALPACA_BASE_URL is string && data.ALPACA_BASE_URL.size() <= 256;
    }

    // Match rules for each blueprint collection pathway
    match /users/{userId} {
      allow read: if isSignedIn() && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidId(userId) && isValidUser(request.resource.data)
        && request.resource.data.uid == resource.data.uid;
    }

    match /users/{userId}/private/credentials {
      allow read: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidCredentials(request.resource.data);
      allow update: if isOwner(userId) && isValidId(userId) && isValidCredentials(request.resource.data);
      allow delete: if isOwner(userId) && isValidId(userId);
    }

    match /globalState/trading {
      allow read: if isSignedIn();
      allow write: if isVerifiedUser();
    }
  }
}
